# Wise Server Environment Variables
# Copy this to .env and fill in your values

# Database (SQLite - file path, no server needed)
DATABASE_URL=sqlite:wise.db?mode=rwc

# Gemini Vision API (optional - app runs in demo mode without this)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Server config
HOST=0.0.0.0
PORT=8080

# Log level (trace, debug, info, warn, error)
RUST_LOG=wise_server=debug,tower_http=info
