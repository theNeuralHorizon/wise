# Wise Server Environment Variables
# Copy this to .env and fill in your values

# Database (SQLite - file path, no server needed)
DATABASE_URL=sqlite:wise.db?mode=rwc

# Gemini Vision API (optional - app runs in demo mode without this)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gemini model (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# AI microservice URL (default: http://localhost:5000/parse)
AI_SERVICE_URL=http://localhost:5000/parse

# Server config
HOST=0.0.0.0
PORT=8081

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# Base URL for generating guest links (default: http://127.0.0.1:{PORT})
BASE_URL=

# Log level (trace, debug, info, warn, error)
RUST_LOG=wise_server=debug,tower_http=info
