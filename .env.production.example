# ─────────────────────────────────────────────────────────────────────────────
# Wise Production Environment Variables
# Copy this to .env.production on Railway and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend (Railway service: backend) ────────────────────────────────────────

# SQLite database path
# NOTE: Railway filesystem is ephemeral — data resets on redeploy.
# To persist: attach a Railway volume to /app/data/ and set:
#   DATABASE_URL=sqlite:/app/data/wise.db?mode=rwc
DATABASE_URL=sqlite:/app/data/wise.db?mode=rwc

# Server binding (do not change)
HOST=0.0.0.0
PORT=8081

# Public backend URL (Railway sets this automatically as RAILWAY_PUBLIC_DOMAIN)
# Set this to your Railway public URL, e.g.: https://wise-backend.up.railway.app
BASE_URL=

# Frontend public URL (used for guest links in API responses)
# Set this to your Cloudflare Pages URL, e.g.: https://wise.pages.dev
PUBLIC_URL=

# CORS — allow your Cloudflare Pages domain + localhost for dev
ALLOWED_ORIGINS=https://wise.pages.dev,http://localhost:5173

# Internal AI service URL (Railway private networking)
# This is automatically resolvable between services in the same Railway project
AI_SERVICE_URL=http://ai_service.railway.internal:5000/parse

# ── AI Service (Railway service: ai_service) ──────────────────────────────────

# Gemini API key for receipt parsing
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# ── Frontend (Cloudflare Pages — set as build env vars) ──────────────────────
# These are baked into the JS at build time via Vite.
# Set in GitHub Actions secrets or Cloudflare Pages build settings:
#
#   VITE_API_BASE_URL = https://your-backend.up.railway.app/api
#
# VITE_WS_BASE_URL — derived automatically from VITE_API_BASE_URL (https→wss, http→ws)
# VITE_FRONTEND_URL — derived automatically from window.location.origin
