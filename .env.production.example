# ─────────────────────────────────────────────────────────────────────────────
# Wise Production Environment Variables
# Copy this file to .env.production and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend ───────────────────────────────────────────────────────────────────

# SQLite database path (persisted via Docker volume)
DATABASE_URL=sqlite:/home/wise/wise.db?mode=rwc

# Server binding (don't change)
HOST=0.0.0.0
PORT=8081

# Base URL for the backend API (used in WS URLs, internal links)
# Example: http://your-server-ip or https://wise.yourdomain.com
BASE_URL=

# Frontend public URL (used for guest links in API responses)
# Example: https://wise.yourdomain.com or http://your-server-ip
# Falls back to BASE_URL if empty
PUBLIC_URL=

# CORS allowed origins (comma-separated)
# Example: http://localhost:5173,https://wise.yourdomain.com
ALLOWED_ORIGINS=*

# ── AI Service ────────────────────────────────────────────────────────────────

# Gemini API key for receipt parsing
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# ── Frontend (Vite build args — set in docker-compose.prod.yml) ──────────────
# These are passed as ARG/ENV during Docker build, not read at runtime.
# VITE_API_BASE_URL=/api        (proxied through nginx)
# VITE_WS_BASE_URL=             (empty = same origin, auto-detected)
# VITE_FRONTEND_URL=            (empty = same origin)
